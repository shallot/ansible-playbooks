---

k8s_gitlab_config_data_dir:
  "{{ k8s_gitlab_config_data_dir_default }}"

# group_vars/k8s-gitlab-runner.yml
k8s_gitlab_agent_server:
  "wss://gitlab.example.com/-/kubernetes-agent/"

k8s_gitlab_agent_token:
  "glagent-testdata"

k8s_gitlab_agent_image:
  "v18.8.0"

k8s_gitlab_runner_url:
  "https://gitlab.example.com/"

k8s_gitlab_runner_token:
  "glrt-testdata"

k8s_gitlab_runner_cpu_request:
  "100m"

k8s_gitlab_runner_cpu_limit:
  "1"

k8s_gitlab_runner_memory_request:
  "256Mi"

k8s_gitlab_runner_memory_limit:
  "2Gi"

k8s_gitlab_runner_replica_count:
  1

k8s_gitlab_agent_replica_count:
  1

k8s_gitlab_runner_registry_url:
  "gitlab-container-registry.example.com:5050"

# identifier-deploy-token @ https://gitlab.example.com/groups/mygroup/-/settings/repository#js-deploy-tokens
k8s_gitlab_runner_registry_username:
  "gitlab+deploy-token-1"
k8s_gitlab_runner_registry_password:
  "gldt-testdata"

# https://docs.ansible.com/ansible/latest/user_guide/intro_inventory.html
vagrant_groups:
  - "k8s-nodes"
  - "microk8s-nodes"
  - "k8s-gitlab-runners"
  - "k8s-gitlab-agents"

# https://www.vagrantup.com/intro/getting-started/networking.html
vagrant_networks:
  - private_network:
      ip: "10.8.60.11"

# https://www.vagrantup.com/docs/provisioning/ansible.html
vagrant_playbooks:
  - "provision-custom-systems.yml"
  - "provision-k8s-nodes.yml"
