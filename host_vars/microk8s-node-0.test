---

# group_vars/microk8s-nodes.yml
microk8s_channel:
  "{{ microk8s_channel_default }}"
test_microk8s_addons__to_merge:
  "{{ microk8s_addons_default }}"

# group_vars/k8s-gateway-api.yml
# tasks/k8s.yml
k8s_gateway_api_version:
  "{{ k8s_gateway_api_version_default }}"

# tasks/k8s-helm-releases.yml
test_k8s_helm_releases__to_merge:
  - name: "traefik"
    namespace: "traefik"
    create_namespace: true
    repo: "traefik"
    repo_url: "https://traefik.github.io/charts"
    chart: "traefik"

# https://docs.ansible.com/ansible/latest/user_guide/intro_inventory.html
vagrant_groups:
  - "k8s-nodes"
  - "microk8s-nodes"
  - "k8s-gateway-api"

# https://www.vagrantup.com/intro/getting-started/networking.html
vagrant_networks:
  - private_network:
      ip: "10.8.60.10"

# https://www.vagrantup.com/docs/provisioning/ansible.html
vagrant_playbooks:
  - "provision-custom-systems.yml"
  - "provision-k8s-nodes.yml"
